using System.Net;
using System.Net.Sockets;
using System.Text;

var server = new TcpListener(IPAddress.Any, 5000);
server.Start();
Console.WriteLine("Server started, Waiting for client...");

var client = await server.AcceptTcpClientAsync();
Console.WriteLine("Client connected!");

var stream = client.GetStream();
var reader = new StreamReader(stream, Encoding.UTF8);
var writer = new StreamWriter(stream, Encoding.UTF8) { AutoFlush = true };

_ = Task.Run(async () => {
    while (true) {
        var msg = await reader.ReadLineAsync();
        if (msg == null) break;
        Console.WriteLine($"Client: {msg.ToUpper()}");
    }
});

while (true) {
    var input = Console.ReadLine();
    await writer.WriteLineAsync(input);
}```

```cs
using System.Net;
using System.Net.Sockets;

var server = new TcpListener(IPAddress.Any, 5001);
server.Start();
Console.WriteLine("File server on port 5001. Waiting for client...");

var client = await server.AcceptTcpClientAsync();
Console.WriteLine("Client connected!");

var stream = client.GetStream();
var reader = new BinaryReader(stream);

while (true) {
    var fileName = reader.ReadString();
    var fileSize = reader.ReadInt64();
    var data = reader.ReadBytes((int)fileSize);

    File.WriteAllBytes(fileName, data);
    Console.WriteLine($"Received: {fileName} ({fileSize} bytes)");
}```

```cs
using System.Net.Sockets;

var client = new TcpClient();
await client.ConnectAsync("127.0.0.1", 5001);
Console.WriteLine("Connected! Enter file paths to send (one per line):\n");

var stream = client.GetStream();
var writer = new BinaryWriter(stream);

while (true) {
    var path = Console.ReadLine();
    if (!File.Exists(path)) { Console.WriteLine("File not found."); continue; }

    var data = File.ReadAllBytes(path);
    writer.Write(Path.GetFileName(path));
    writer.Write((long)data.Length);
    writer.Write(data);
    writer.Flush();

    Console.WriteLine($"Sent: {Path.GetFileName(path)} ({data.Length} bytes)");
}```
